{
  "name": "vencebuddy",
  "version": "0.1.0",
  "description": "OpenClaw-based AI workbench powered by DeepSeek LLM + SeedDance video generation",
  "main": "src/main/index.ts",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac"
  },
  "keywords": [
    "openclaw",
    "deepseek",
    "seeddance",
    "ai-agent",
    "electron",
    "workbench"
  ],
  "author": "VenceGuo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "openai": "^4.70.0",
    "better-sqlite3": "^11.5.0",
    "electron-store": "^10.0.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0",
    "lucide-react": "^0.460.0",
    "tailwindcss": "^3.4.0",
    "clsx": "^2.1.0"
  },
  "build": {
    "appId": "com.venceguo.vencebuddy",
    "productName": "VenceBuddy",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns"
    }
  }
}