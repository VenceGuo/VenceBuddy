# ============================================================
# VenceBuddy - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: .env is gitignored and will NEVER be committed.
# Never share your real tokens. If exposed, rotate immediately.
# ============================================================

# ---- Git Tokens ----
# GitHub Personal Access Token (Fine-grained)
# Required scopes: Contents (Read and Write), Metadata (Read)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Gitee Private Access Token
# Required scopes: projects, user_info
# Create at: https://gitee.com/profile/personal_access_tokens
GITEE_TOKEN=your_gitee_token_here

# ---- SiliconFlow API (统一 LLM + 视频生成) ----
# 一个 Key 同时用于 DeepSeek LLM 对话和 Wan2.2 视频生成
# 注册地址: https://cloud.siliconflow.cn
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ---- Optional ----
# Default LLM model (via SiliconFlow)
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V4-Pro
DEEPSEEK_API_BASE=https://api.siliconflow.cn/v1

# SiliconFlow API base (LLM + 视频生成共用)
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# Video generation model (Wan2.2 series)
# Wan-AI/Wan2.2-T2V-A14B = text-to-video
# Wan-AI/Wan2.2-I2V-A14B = image-to-video
VIDEO_MODEL=Wan-AI/Wan2.2-T2V-A14B
