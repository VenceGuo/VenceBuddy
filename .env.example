# ============================================================
# VenceBuddy - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: .env is gitignored and will NEVER be committed.
# Never share your real tokens. If exposed, rotate immediately.
# ============================================================

# ---- Git Tokens ----
# GitHub Personal Access Token (Fine-grained)
# Required scopes: Contents (Read and Write), Metadata (Read)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Gitee Private Access Token
# Required scopes: projects, user_info
# Create at: https://gitee.com/profile/personal_access_tokens
GITEE_TOKEN=your_gitee_token_here

# ---- LLM API Keys ----
# DeepSeek API Key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ---- Video Generation API Keys ----
# SeedDance API Key (https://seeddance.ai/)
SEEDDANCE_API_KEY=your_seeddance_api_key_here

# ---- Optional ----
# Default model for DeepSeek
DEEPSEEK_MODEL=deepseek-chat

# SeedDance API endpoint (leave default unless using proxy)
SEEDDANCE_API_BASE=https://api.seeddance.ai/v1
